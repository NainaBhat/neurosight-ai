# NeuroSight AI - Backend Environment Variables
PORT=5000
FLASK_ENV=development

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=neurosight

# Model file paths (relative to backend/ directory)
VGG16_MODEL_PATH=models/brain_tumor_detection_vgg16.keras
EFFNET_MODEL_PATH=models/brain_tumor_detection_efficientnetb0.keras

# CORS — set to your Vercel frontend URL in production
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
